<launch> 
    <node name="ik_saber_d6x" pkg="hex_ros_ik_saber_d6x" type="ik_saber_d6x.py" output="screen" >
        # parameter
        <rosparam file="$(find hex_ros_ik_saber_d6x)/config/ros1/params.yaml"/>
        # subscribe
        <remap from="/in_str" to="/in_str" />
        <remap from="/in_int" to="/in_int" />
        # publish
        <remap from="/out_str" to="/out_str" />
        <remap from="/out_int" to="/out_int" />
    </node>    
</launch>
